{
  "name": "@zenalexa/unicli",
  "version": "0.221.1",
  "description": "Agent execution substrate for web, apps, local tools, and system capabilities. Self-repairing CLI catalog with stdio + Streamable HTTP MCP server.",
  "packageManager": "npm@11.14.0",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "unicli": "dist/main.js",
    "unicli-mcp": "bin/unicli-mcp"
  },
  "files": [
    "bin/",
    "dist/",
    "crates/",
    "docs/operate/",
    "docs/mcp/clients/",
    "src/adapters/",
    "src/hub/",
    "skills/unicli/",
    "skills/unicli-browser/",
    "skills/unicli-claude-code/",
    "skills/unicli-explorer/",
    "skills/unicli-hermes/",
    "skills/unicli-oneshot/",
    "skills/unicli-operate/",
    "skills/unicli-repair/",
    "skills/unicli-smart-search/",
    "skills/unicli-usage/",
    "skills/talk-normal/",
    "skills/README.md",
    "server.json",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./registry-v2": {
      "types": "./dist/core/registry.d.ts",
      "import": "./dist/core/registry.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./output": {
      "types": "./dist/output/formatter.d.ts",
      "import": "./dist/output/formatter.js"
    },
    "./engine": {
      "types": "./dist/engine/executor.d.ts",
      "import": "./dist/engine/executor.js"
    },
    "./engine/registry": {
      "types": "./dist/engine/step-registry.d.ts",
      "import": "./dist/engine/step-registry.js"
    },
    "./engine/steps": {
      "types": "./dist/engine/steps/index.d.ts",
      "import": "./dist/engine/steps/index.js"
    },
    "./transport": {
      "types": "./dist/transport/bus.d.ts",
      "import": "./dist/transport/bus.js"
    },
    "./transport/http": {
      "types": "./dist/transport/adapters/http.d.ts",
      "import": "./dist/transport/adapters/http.js"
    },
    "./transport/cdp-browser": {
      "types": "./dist/transport/adapters/cdp-browser.d.ts",
      "import": "./dist/transport/adapters/cdp-browser.js"
    },
    "./transport/subprocess": {
      "types": "./dist/transport/adapters/subprocess.d.ts",
      "import": "./dist/transport/adapters/subprocess.js"
    },
    "./transport/desktop-ax": {
      "types": "./dist/transport/adapters/desktop-ax.d.ts",
      "import": "./dist/transport/adapters/desktop-ax.js"
    },
    "./transport/cua": {
      "types": "./dist/transport/adapters/cua.d.ts",
      "import": "./dist/transport/adapters/cua.js"
    },
    "./browser/cdp": {
      "types": "./dist/browser/cdp-client.d.ts",
      "import": "./dist/browser/cdp-client.js"
    },
    "./browser/page": {
      "types": "./dist/browser/page.d.ts",
      "import": "./dist/browser/page.js"
    },
    "./browser/daemon": {
      "types": "./dist/browser/daemon-client.d.ts",
      "import": "./dist/browser/daemon-client.js"
    },
    "./browser/utils": {
      "types": "./dist/browser/dom-helpers.d.ts",
      "import": "./dist/browser/dom-helpers.js"
    },
    "./protocol/mcp": {
      "types": "./dist/mcp/schema.d.ts",
      "import": "./dist/mcp/schema.js"
    },
    "./protocol/acp": {
      "types": "./dist/protocol/acp.d.ts",
      "import": "./dist/protocol/acp.js"
    },
    "./agents/backends": {
      "types": "./dist/agents/backends.d.ts",
      "import": "./dist/agents/backends.js"
    },
    "./protocol/skill": {
      "types": "./dist/protocol/skill.d.ts",
      "import": "./dist/protocol/skill.js"
    },
    "./download": {
      "types": "./dist/engine/download.d.ts",
      "import": "./dist/engine/download.js"
    },
    "./pipeline": {
      "types": "./dist/engine/executor.d.ts",
      "import": "./dist/engine/executor.js"
    }
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "npm run clean && tsc && tsx scripts/build-manifest.js && tsx scripts/count-stats.ts && tsx scripts/build-readme.ts && tsx scripts/build-agents.ts && prettier --write AGENTS.md",
    "postbuild": "node -e \"const fs=require('fs'); fs.chmodSync('dist/main.js', 0o755); fs.chmodSync('dist/bin/unicli-mcp.js', 0o755); fs.chmodSync('bin/unicli-mcp', 0o755);\"",
    "stats": "tsx scripts/build-manifest.js && tsx scripts/count-stats.ts && tsx scripts/build-readme.ts && tsx scripts/build-agents.ts",
    "stats:check": "tsx scripts/count-consistency.ts",
    "build:agents": "tsx scripts/build-agents.ts",
    "test": "vitest run --project unit",
    "test:adapter": "vitest run --project adapter",
    "test:perf": "vitest run --project perf",
    "compute:smoke": "tsx scripts/compute-live-smoke.ts",
    "coverage:compute-snapshot": "vitest run --project unit tests/unit/refs.test.ts tests/unit/snapshot-encoder.test.ts --coverage --coverage.enabled=true --coverage.provider=v8 --coverage.include=src/transport/refs.ts --coverage.include=src/transport/snapshot-encoder.ts --coverage.reporter=text --coverage.thresholds.lines=100 --coverage.thresholds.functions=100 --coverage.thresholds.branches=100 --coverage.thresholds.statements=100",
    "coverage:adapter-test": "tsx scripts/check-adapter-test-coverage.ts --threshold 50",
    "adapter:bootstrap": "tsx scripts/bootstrap-adapter-tests.ts",
    "adapter:health": "tsx scripts/adapter-health-probe.ts",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:context": "bash scripts/lint-context.sh",
    "build:manifest": "tsx scripts/build-manifest.js",
    "sidecars:build": "node scripts/build-sidecars.mjs",
    "sidecars:publish": "node scripts/publish-sidecars.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --since=origin/main",
    "verify:changesets": "tsx scripts/verify-changesets.ts",
    "verify:release-mainline": "tsx scripts/release-mainline-check.ts",
    "conformance": "tsx scripts/conformance-report.ts",
    "check:exports": "tsx scripts/check-exports-count.ts",
    "lint:adapters": "tsx src/main.ts lint src/adapters",
    "lint:schema-v2": "tsx scripts/lint-schema-v2.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "validate:agents-size": "tsx scripts/validate-agents-size.ts",
    "boundary:check": "tsx scripts/boundary-guard.ts",
    "verify": "npm run format:check && npm run typecheck && npm run lint && npm run lint:context && npm run build:manifest && npm run lint:adapters && npm run lint:schema-v2 && npm run build && npm run test && npm run test:adapter && npm run test:perf && npm run coverage:compute-snapshot && npm run coverage:adapter-test && npm run validate:agents-size && npm run stats:check && npm run conformance && npm run check:exports && npm run verify:changesets && npm run boundary:check",
    "verify:full": "npm run verify && npm run adapter:health",
    "verify:clean": "npm run clean && npm run verify",
    "docs:prepare": "tsx scripts/generate-catalog.ts && tsx scripts/generate-docs-agent-assets.ts",
    "docs:dev": "npm run docs:prepare && vitepress dev docs",
    "docs:check-public": "tsx scripts/check-public-docs.ts",
    "docs:build": "npm run docs:prepare && node -e \"require('node:fs').rmSync('docs/.vitepress/dist',{recursive:true,force:true})\" && vitepress build docs && npm run docs:check-public",
    "docs:preview": "vitepress preview docs",
    "doctor": "tsx src/doctor.ts",
    "mcp": "tsx src/mcp/server.ts",
    "release": "npm run verify:release-mainline && npm run build && tsx scripts/release.ts",
    "release:check": "tsx scripts/release-check.ts",
    "prepare": "lefthook install >/dev/null 2>&1 || true",
    "preversion": "npm run verify:release-mainline && npm run verify",
    "postversion": "npm run build && tsx scripts/release.ts",
    "bench": "tsx bench/report.ts",
    "bench:self-discovery": "tsx bench/self-discovery.ts",
    "bench:surface-coverage": "tsx bench/surface-coverage.ts",
    "bench:quick": "tsx bench/agent/report.ts",
    "bench:agent": "tsx bench/agent/sdk-runner.ts",
    "bench:gate": "node scripts/bench/check-ship-gate.js",
    "sync:ref": "bash scripts/sync-ref.sh"
  },
  "keywords": [
    "cli",
    "ai-agent",
    "browser-automation",
    "desktop-automation",
    "mcp",
    "cli-hub",
    "agent-tools",
    "claude-code",
    "codex",
    "cursor"
  ],
  "author": "ZenAlexa",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olo-dot-io/Uni-CLI.git"
  },
  "homepage": "https://olo-dot-io.github.io/Uni-CLI/",
  "bugs": {
    "url": "https://github.com/olo-dot-io/Uni-CLI/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fast-xml-parser": "^5.8.0",
    "js-yaml": "^4.1.1",
    "jsonpath-plus": "^10.4.0",
    "turndown": "^7.2.4",
    "undici": "^7.25.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@zenalexa/unicli-atspi-linux-arm64": "0.218.1",
    "@zenalexa/unicli-atspi-linux-x64": "0.218.1",
    "@zenalexa/unicli-uia-win32-arm64": "0.218.1",
    "@zenalexa/unicli-uia-win32-x64": "0.218.1"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@base-ui/react": "^1.4.1",
    "@changesets/cli": "^2.31.0",
    "@chenglou/pretext": "^0.0.6",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@hugeicons/vue": "^1.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "ai": "^6.0.168",
    "lefthook": "^2.1.6",
    "markdown-it-mathjax3": "^4.3.2",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shell-quote": "^1.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "yaml": "^2.8.3"
  }
}
