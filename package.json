{
  "name": "@zenalexa/unicli",
  "version": "0.213.0-beta.1",
  "description": "The universal interface between AI agents and the world's software",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "unicli": "dist/main.js"
  },
  "files": [
    "dist/",
    "src/adapters/",
    "src/hub/",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./registry": {
      "types": "./dist/registry.d.ts",
      "import": "./dist/registry.js"
    },
    "./registry-v2": {
      "types": "./dist/core/registry.d.ts",
      "import": "./dist/core/registry.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./output": {
      "types": "./dist/output/formatter.d.ts",
      "import": "./dist/output/formatter.js"
    },
    "./engine": {
      "types": "./dist/engine/executor.d.ts",
      "import": "./dist/engine/executor.js"
    },
    "./engine/registry": {
      "types": "./dist/engine/step-registry.d.ts",
      "import": "./dist/engine/step-registry.js"
    },
    "./engine/steps": {
      "types": "./dist/engine/steps/index.d.ts",
      "import": "./dist/engine/steps/index.js"
    },
    "./transport": {
      "types": "./dist/transport/bus.d.ts",
      "import": "./dist/transport/bus.js"
    },
    "./transport/http": {
      "types": "./dist/transport/adapters/http.d.ts",
      "import": "./dist/transport/adapters/http.js"
    },
    "./transport/cdp-browser": {
      "types": "./dist/transport/adapters/cdp-browser.d.ts",
      "import": "./dist/transport/adapters/cdp-browser.js"
    },
    "./transport/subprocess": {
      "types": "./dist/transport/adapters/subprocess.d.ts",
      "import": "./dist/transport/adapters/subprocess.js"
    },
    "./transport/desktop-ax": {
      "types": "./dist/transport/adapters/desktop-ax.d.ts",
      "import": "./dist/transport/adapters/desktop-ax.js"
    },
    "./transport/cua": {
      "types": "./dist/transport/adapters/cua.d.ts",
      "import": "./dist/transport/adapters/cua.js"
    },
    "./browser/cdp": {
      "types": "./dist/browser/cdp-client.d.ts",
      "import": "./dist/browser/cdp-client.js"
    },
    "./browser/page": {
      "types": "./dist/browser/page.d.ts",
      "import": "./dist/browser/page.js"
    },
    "./browser/daemon": {
      "types": "./dist/browser/daemon-client.d.ts",
      "import": "./dist/browser/daemon-client.js"
    },
    "./browser/utils": {
      "types": "./dist/browser/dom-helpers.d.ts",
      "import": "./dist/browser/dom-helpers.js"
    },
    "./protocol/mcp": {
      "types": "./dist/mcp/schema.d.ts",
      "import": "./dist/mcp/schema.js"
    },
    "./protocol/acp": {
      "types": "./dist/protocol/acp.d.ts",
      "import": "./dist/protocol/acp.js"
    },
    "./protocol/skill": {
      "types": "./dist/protocol/skill.d.ts",
      "import": "./dist/protocol/skill.js"
    },
    "./download": {
      "types": "./dist/engine/download.d.ts",
      "import": "./dist/engine/download.js"
    },
    "./pipeline": {
      "types": "./dist/engine/executor.d.ts",
      "import": "./dist/engine/executor.js"
    }
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && tsx scripts/build-manifest.js && tsx scripts/count-stats.ts && tsx scripts/build-readme.ts && tsx scripts/build-agents.ts && npx prettier --write AGENTS.md",
    "stats": "tsx scripts/count-stats.ts && tsx scripts/build-readme.ts",
    "stats:check": "tsx scripts/count-consistency.ts",
    "build:agents": "tsx scripts/build-agents.ts",
    "test": "vitest run --project unit",
    "test:adapter": "vitest run --project adapter",
    "coverage:adapter-test": "tsx scripts/check-adapter-test-coverage.ts --threshold 50",
    "adapter:bootstrap": "tsx scripts/bootstrap-adapter-tests.ts",
    "adapter:health": "tsx scripts/adapter-health-probe.ts",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:context": "bash scripts/lint-context.sh",
    "build:manifest": "tsx scripts/build-manifest.js",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --since=origin/main",
    "verify:changesets": "tsx scripts/verify-changesets.ts",
    "conformance": "tsx scripts/conformance-report.ts",
    "check:exports": "tsx scripts/check-exports-count.ts",
    "lint:adapters": "tsx src/main.ts lint src/adapters",
    "lint:schema-v2": "tsx scripts/lint-schema-v2.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "validate:agents-size": "tsx scripts/validate-agents-size.ts",
    "verify": "npm run format:check && npm run typecheck && npm run lint && npm run lint:context && npm run build:manifest && npm run lint:adapters && npm run lint:schema-v2 && npm run build && npm run test && npm run test:adapter && npm run coverage:adapter-test && npm run validate:agents-size && npm run stats:check && npm run conformance && npm run check:exports && npm run verify:changesets",
    "verify:full": "npm run verify && npm run refs:verify && npm run adapter:health",
    "verify:clean": "npm run clean && npm run verify",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "doctor": "tsx src/doctor.ts",
    "mcp": "tsx src/mcp/server.ts",
    "release": "npm run build && tsx scripts/release.ts",
    "release:check": "tsx scripts/release-check.ts",
    "prepare": "lefthook install 2>/dev/null || true",
    "preversion": "npm run verify",
    "postversion": "npm run build && tsx scripts/release.ts",
    "bench": "tsx bench/report.ts",
    "refs:verify": "tsx scripts/verify-refs.ts",
    "sync:ref": "bash scripts/sync-ref.sh"
  },
  "keywords": [
    "cli",
    "ai-agent",
    "browser-automation",
    "desktop-automation",
    "mcp",
    "cli-hub",
    "agent-tools",
    "claude-code",
    "codex",
    "cursor"
  ],
  "author": "ZenAlexa",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olo-dot-io/Uni-CLI.git"
  },
  "homepage": "https://github.com/olo-dot-io/Uni-CLI",
  "bugs": {
    "url": "https://github.com/olo-dot-io/Uni-CLI/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "turndown": "^7.2.4",
    "undici": "^8.0.2",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.14",
    "lefthook": "^2.1.5",
    "oxlint": "^1.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.0",
    "vitest": "^4.1.4"
  }
}
