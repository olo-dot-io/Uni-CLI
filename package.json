{
  "name": "@zenalexa/unicli",
  "version": "0.211.2",
  "description": "The universal interface between AI agents and the world's software",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "unicli": "dist/main.js"
  },
  "files": [
    "dist/",
    "src/adapters/",
    "src/hub/",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/main.js",
    "./registry": "./dist/registry.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && tsx scripts/build-manifest.js && tsx scripts/build-agents.ts",
    "build:agents": "tsx scripts/build-agents.ts",
    "test": "vitest run --project unit",
    "test:adapter": "vitest run --project adapter",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:context": "bash scripts/lint-context.sh",
    "verify": "npm run format:check && npm run typecheck && npm run lint && npm run lint:context && npm run test && npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "doctor": "tsx src/doctor.ts",
    "mcp": "tsx src/mcp/server.ts",
    "release": "npm run build && tsx scripts/release.ts",
    "release:check": "tsx scripts/release-check.ts",
    "prepare": "lefthook install",
    "preversion": "npm run verify",
    "postversion": "npm run build && tsx scripts/release.ts",
    "bench": "tsx scripts/bench.ts",
    "sync:ref": "bash scripts/sync-ref.sh"
  },
  "keywords": [
    "cli",
    "ai-agent",
    "browser-automation",
    "desktop-automation",
    "mcp",
    "cli-hub",
    "agent-tools",
    "claude-code",
    "codex",
    "cursor"
  ],
  "author": "ZenAlexa",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olo-dot-io/Uni-CLI.git"
  },
  "homepage": "https://github.com/olo-dot-io/Uni-CLI",
  "bugs": {
    "url": "https://github.com/olo-dot-io/Uni-CLI/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "turndown": "^7.2.4",
    "undici": "^8.0.2",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.14",
    "lefthook": "^2.1.5",
    "oxlint": "^1.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.0",
    "vitest": "^3.2.4"
  }
}
